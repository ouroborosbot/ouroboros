{
  "name": "slugger",
  "provider": "anthropic",
  "configPath": "~/.agentsecrets/slugger/secrets.json",
  "context": {
    "maxTokens": 80000,
    "contextMargin": 20
  },
  "phrases": {
    "thinking": [
      "working"
    ],
    "tool": [
      "running tool"
    ],
    "followup": [
      "processing"
    ]
  }
}
