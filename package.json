{
  "name": "ouroboros",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsc && node dist/cli-entry.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "teams": "tsc && node dist/teams-entry.js",
    "teams:no-stream": "tsc && node dist/teams-entry.js --disable-streaming",
    "manifest:package": "cd manifest && zip -r ../manifest.zip manifest.json color.png outline.png"
  },
  "dependencies": {
    "@microsoft/teams.apps": "^2.0.5",
    "@microsoft/teams.dev": "^2.0.5",
    "openai": "^4.78.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
