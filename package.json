{
  "name": "ouroboros-agent-harness",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsc && node dist/cli-entry.js --agent ouroboros",
    "dev:slugger": "tsc && node dist/cli-entry.js --agent slugger",
    "auth:openai-codex": "node scripts/auth-openai-codex.cjs --agent ouroboros",
    "auth:claude-setup-token": "node scripts/auth-claude-setup-token.cjs --agent ouroboros",
    "test": "vitest run",
    "test:coverage:vitest": "vitest run --coverage",
    "audit:nerves": "npm run build && node dist/nerves/coverage/cli-main.js",
    "test:coverage": "node scripts/run-coverage-gate.cjs",
    "teams": "tsc && node dist/teams-entry.js --agent ouroboros",
    "manifest:package": "cd ouroboros/manifest && zip -r ../../manifest.zip manifest.json color.png outline.png",
    "reflect": "tsc && node dist/reflection/reflect-entry.js --agent ouroboros",
    "reflect:dry": "tsc && node dist/reflection/reflect-entry.js --agent ouroboros --dry-run",
    "reflect:loop": "tsc && node dist/reflection/loop-entry.js --agent ouroboros",
    "reflect:loop:dry": "tsc && node dist/reflection/loop-entry.js --agent ouroboros --dry-run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@microsoft/teams.apps": "^2.0.5",
    "@microsoft/teams.dev": "^2.0.5",
    "openai": "^4.78.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
